{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch with File Path",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/pedroldm/MSc/cbm/src/CBMLKH/main_debug",
            "args": [
                "/home/pedroldm/MSc/cbm/src/CBMLKH/parameters.md"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
